# ─────────────────────────────────────────────────────────────────
#  NHS Clinical Referral Safety Automation — environment template
#  Copy to .env and fill in. NEVER commit the real .env.
#  All data in this project is SYNTHETIC. No real patient data.
# ─────────────────────────────────────────────────────────────────

# --- OpenMRS (mock EPR/EMR) ---
OPENMRS_BASE_URL=http://localhost/openmrs
OPENMRS_REST_URL=http://localhost/openmrs/ws/rest/v1
OPENMRS_USERNAME=admin
OPENMRS_PASSWORD=Admin123

# --- LLM extraction (optional; regex fallback used if unset) ---
USE_LLM=true
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions
GROQ_MODEL=llama-3.3-70b-versatile
LLM_TIMEOUT_SECONDS=30

# --- Extraction service (local) ---
EXTRACTION_SERVICE_URL=http://localhost:8089
EXTRACTION_CONFIDENCE_THRESHOLD=0.75

# --- Audit trail (append-only CSV: who/what/before/after/when/why) ---
AUDIT_LOG_PATH=./data/audit/audit-log.csv

# --- Safety / business rules ---
PATIENT_MATCH_STRICT_MODE=true
DUPLICATE_REFERRAL_LOOKBACK_DAYS=180

# --- Human review ---
ENABLE_ACTION_CENTER=false
ENABLE_MOCK_HUMAN_REVIEW=true
REVIEW_DB_PATH=./services/review-service-optional/review.db
