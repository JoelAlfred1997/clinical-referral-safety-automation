# ── Secrets & environment ─────────────────────────────────────────
.env
*.env
!.env.example
**/secrets/**
*.secret
*.key
*.pem

# ── UiPath ────────────────────────────────────────────────────────
.local/
.settings/
.objects/
**/.tmh/
**/obj/
**/bin/
*.nupkg

# ── Python extraction/audit services ──────────────────────────────
__pycache__/
*.pyc
.venv/
venv/
.pytest_cache/
.mypy_cache/

# Generated, environment-specific OpenMRS UUIDs (regenerate via setup_referral_metadata.py)
services/openmrs-workflow/config/referral-metadata.json

# ── Runtime data (synthetic, but keep the repo clean) ─────────────
data/processed/*
data/failed/*
data/review/*
data/extracted-json/*
data/decisions/*
!data/**/.gitkeep
reports/*.xlsx
*.sqlite
*.db
audit*.db

# ── OS / IDE ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.log
# Office lock/temp files (e.g. ~$Build-Progress-Log.docx)
~$*

# ── Claude Code local settings ────────────────────────────────────
.claude/settings.local.json

# NOTE: data/input-referrals and data/synthetic-patients ARE committed
#       because they are synthetic test fixtures, not runtime output.
data/audit/*
!data/audit/.gitkeep
**/Exceptions_Screenshots/*.png

# ── Personal / internal docs (kept locally, not published) ─────────
docs/Build-Progress-Log.docx
docs/Project-Explained-Simply.docx
docs/Project-Explained-Simply.md
docs/Project-Explained-Simply.assets/
docs/build-log/
# CV/LinkedIn/interview material — personal, kept locally
docs/cv-linkedin/
# Native-UiPath rebuild guide — personal working doc (md + docx)
docs/uipath-native-build-guide.*

# ── UiPath generated / template artifacts (not portfolio source) ───
**/.project/
**/*.xaml.json
# Third-party REFramework manual shipped with the template
**/Documentation/*.pdf
# Stock REFramework test-case stubs (boilerplate, not authored tests)
uipath/NHS.ReferralSafety.Performer/Tests/

# ── Vestigial empty service dir (audit trail is the CSV in data/audit) ─
services/audit-service/
